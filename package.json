{
  "name": "@yourusername/webgameengine",
  "version": "0.1.0",
  "description": "A lightweight web game engine framework with TypeScript support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run tools/build.ts",
    "build": "ts-node engine/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/webgameengine.git"
  },
  "keywords": [
    "game",
    "engine",
    "gamedev",
    "2d",
    "web",
    "typescript"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "esbuild": "^0.18.18",
    "ws": "^8.17.0",
    "typescript": "^5.2.2",
    "@types/node": "^20.5.1",
    "@types/ws": "^8.5.6",
    "ts-node": "^10.9.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
